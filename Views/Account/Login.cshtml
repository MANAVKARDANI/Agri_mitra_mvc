@model LoginViewModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <title>Login</title>
    <link href="https://cdn.jsdelivr.net/npm/tailwindcss@2.2.19/dist/tailwind.min.css" rel="stylesheet">
</head>

<body class="bg-gray-200 min-h-screen flex items-center justify-center p-6">

    <div class="bg-white rounded-2xl shadow-2xl w-full max-w-6xl flex overflow-hidden">

        <div class="w-full md:w-1/2 p-10 lg:p-14">

            <h1 class="text-2xl font-bold">AGRI-MITRA</h1>

            <h2 class="text-xl mt-10 font-semibold">Welcome back!</h2>

            <form method="post" class="space-y-6">

                <select name="Role" class="w-full p-3 border rounded-lg bg-gray-100">
                    <option value="">Select Role</option>
                    <option>Admin</option>
                    <option>Supplier</option>
                    <option>User</option>
                </select>

                <input type="email" name="Email" placeholder="Email" class="w-full p-3 border rounded-lg bg-gray-100" />

                <input type="password" name="Password" placeholder="Password" class="w-full p-3 border rounded-lg bg-gray-100" />

                @if (ViewBag.Error != null)
                {
                    <p class="text-red-500">@ViewBag.Error</p>
                }

                <button class="w-full bg-green-800 text-white py-3 rounded-full">Login</button>

            </form>

            <p class="text-center mt-4">
                <a href="/Account/Register">Sign Up</a>
            </p>

            <p class="text-center">
                <a href="/Account/ForgotPassword">Forgot Password?</a>
            </p>

        </div>

    </div>

</body>
</html>