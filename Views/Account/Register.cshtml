@model RegisterViewModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <title>Register</title>
    <link href="https://cdn.jsdelivr.net/npm/tailwindcss@2.2.19/dist/tailwind.min.css" rel="stylesheet">
</head>

<body class="bg-gray-200 min-h-screen flex items-center justify-center p-6">

    <div class="bg-white rounded-2xl shadow-2xl w-full max-w-4xl p-10">

        <h2 class="text-3xl font-bold">Register</h2>

        <form method="post" class="space-y-5 mt-6">

            <input name="FirstName" placeholder="First Name" class="w-full p-3 border rounded-lg bg-gray-100" />

            <input name="LastName" placeholder="Last Name" class="w-full p-3 border rounded-lg bg-gray-100" />

            <input name="Email" placeholder="Email" class="w-full p-3 border rounded-lg bg-gray-100" />

            <input name="BusinessName" placeholder="Business Name" class="w-full p-3 border rounded-lg bg-gray-100" />

            <input type="password" name="Password" placeholder="Password" class="w-full p-3 border rounded-lg bg-gray-100" />

            <button class="w-full bg-green-800 text-white py-3 rounded-lg">Create Account</button>

        </form>

        <p class="text-center mt-4">
            <a href="/Account/Login">Login</a>
        </p>

    </div>

</body>
</html>