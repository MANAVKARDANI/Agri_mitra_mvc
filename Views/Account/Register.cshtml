@model RegisterViewModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <title>Register</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-gray-200 min-h-screen flex items-center justify-center p-6">

    <div class="bg-white rounded-2xl shadow-2xl w-full max-w-7xl flex overflow-hidden">

        <!-- LEFT GREEN PANEL -->
        <div class="hidden lg:flex w-1/4 bg-green-800 text-white flex-col justify-between p-10">

            <h1 class="text-xl font-bold">AGRI-MITRA</h1>

            <div class="space-y-10">

                <div>
                    <p class="text-xs uppercase">Community</p>
                    <h2 class="text-4xl font-bold">10k+</h2>
                    <p class="text-sm">Farmers optimizing yields daily.</p>
                </div>

                <div class="border-t pt-6">
                    <p class="text-xs uppercase">Speed</p>
                    <h2 class="text-3xl font-bold">Real-time</h2>
                    <p class="text-sm">Instant stock alerts.</p>
                </div>

            </div>

            <div class="text-xs">© 2026 AGRI-MITRA</div>

        </div>

        <!-- FORM -->
        <div class="w-full lg:w-2/4 p-12">

            <div class="max-w-md mx-auto">

                <h2 class="text-3xl font-bold">Join the Network</h2>

                <form method="post" asp-action="Register" class="mt-8 space-y-5">

                    <div class="grid grid-cols-2 gap-4">
                        <input name="FirstName" placeholder="First Name" class="p-3 border rounded-lg bg-gray-100" />
                        <input name="LastName" placeholder="Last Name" class="p-3 border rounded-lg bg-gray-100" />
                    </div>

                    <input name="Email" placeholder="Email" class="w-full p-3 border rounded-lg bg-gray-100" />
                    <input name="BusinessName" placeholder="Business Name" class="w-full p-3 border rounded-lg bg-gray-100" />
                    <input name="Password" type="password" placeholder="Password" class="w-full p-3 border rounded-lg bg-gray-100" />

                    <button class="w-full bg-green-800 text-white py-3 rounded-lg">
                        Create Account
                    </button>

                </form>

                <p class="text-center mt-6">
                    Already a member?
                    <a href="/Account/Login" class="text-green-700">Login</a>
                </p>

            </div>

        </div>

        <!-- RIGHT IMAGE -->
        <div class="hidden lg:block w-1/4">
            <img src="~/images/register.png" class="h-full w-full object-cover" />
        </div>

    </div>

</body>
</html>