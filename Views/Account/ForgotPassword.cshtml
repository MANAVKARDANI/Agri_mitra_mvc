@model ForgotPasswordViewModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <title>Forgot Password</title>
    <link href="https://cdn.jsdelivr.net/npm/tailwindcss@2.2.19/dist/tailwind.min.css" rel="stylesheet">
</head>

<body class="bg-gray-200 min-h-screen flex items-center justify-center p-6">

    <div class="bg-white rounded-2xl shadow-2xl w-full max-w-xl p-10">

        <h2 class="text-2xl font-bold">Forgot Password</h2>

        <form method="post" class="mt-6 space-y-4">

            <input name="Email" placeholder="Enter Email" class="w-full p-3 border rounded-lg bg-gray-100" />

            <button class="w-full bg-green-800 text-white py-3 rounded-full">
                Send Reset Link
            </button>

        </form>

        @if (ViewBag.Message != null)
        {
            <p class="text-green-600 mt-4">@ViewBag.Message</p>
        }

        <p class="text-center mt-4">
            <a href="/Account/Login">Back to Login</a>
        </p>

    </div>

</body>
</html>