@model ForgotPasswordViewModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <title>Forgot Password</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-gray-200 min-h-screen flex items-center justify-center p-6">

    <div class="bg-white rounded-2xl shadow-2xl w-full max-w-7xl flex overflow-hidden">

        <!-- LEFT -->
        <div class="w-full lg:w-1/2 p-12">

            <h1 class="text-green-700 font-bold text-xl">AGRI-MITRA</h1>

            <h2 class="text-3xl font-bold mt-6">Forgot Password?</h2>

            <p class="text-gray-500 mb-6">
                Enter your email to receive reset link
            </p>

            <form method="post" asp-action="ForgotPassword">

                <input name="Email" type="email"
                       class="w-full p-3 border rounded-lg bg-gray-100" />

                <button class="w-full mt-6 bg-green-800 text-white py-3 rounded-full">
                    Send Reset Link
                </button>

            </form>

            <a href="/Account/Login" class="block text-center mt-6 text-green-700">
                ← Back to Login
            </a>

        </div>

        <!-- RIGHT IMAGE -->
        <div class="hidden lg:block w-1/2 relative">

            <img src="~/images/forgotpass.png"
                 class="h-full w-full object-cover" />

            <div class="absolute bottom-10 left-10 text-white">
                "Ensuring every field gets what it needs"
            </div>

        </div>

    </div>

</body>
</html>