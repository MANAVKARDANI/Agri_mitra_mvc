@{
    var shopName = ViewBag.ShopName;
    var shopImage = ViewBag.ShopImage;
    var shopAddress = ViewBag.ShopAddress;

    var products = new List<dynamic>
    {
        new { Name = "Imported Super Potash", Img = "/images/potash.png" },
        new { Name = "Urea Fertilizer", Img = "/images/UREA.png" },
        new { Name = "Bio DAP", Img = "/images/Bio dap.png" }
    };
}

<div class="bg-white">

    <!-- HERO -->
    <section class="relative">
        <div class="h-[350px] w-full relative">
            <img src="@shopImage"
                 class="w-full h-full object-cover"
                 alt="@shopName" />

            <div class="absolute inset-0 bg-black/40"></div>

            <div class="absolute inset-0 flex flex-col justify-center items-center text-white text-center">
                <h1 class="text-5xl font-bold mb-2">@shopName</h1>

                <p class="uppercase tracking-widest text-sm">
                    Premium Agricultural Solutions
                </p>
            </div>
        </div>
    </section>

    <!-- STORE INFO -->
    <section class="py-16 max-w-7xl mx-auto px-6">
        <div class="flex flex-col md:flex-row gap-12">

            <!-- IMAGE -->
            <div class="overflow-hidden rounded-2xl group">
                <img src="@shopImage"
                     class="rounded-2xl w-full md:w-[520px] object-cover transition duration-700 group-hover:scale-105"
                     alt="@shopName" />
            </div>

            <!-- TEXT -->
            <div class="md:w-1/2">
                <h2 class="text-4xl font-bold mb-6">
                    Your Partner in Sustainable Farming
                </h2>

                <p class="text-gray-500 mb-8 leading-relaxed">
                    Welcome to @shopName. We provide high-quality fertilizers and
                    professional agricultural nutrients designed to improve crop
                    productivity and soil health.
                </p>

                <div class="space-y-4 text-sm text-gray-600">
                    <p class="flex items-center gap-2">📍 @shopAddress</p>
                    <p class="flex items-center gap-2">⏰ Mon–Fri: 9:00 – 22:00</p>
                    <p class="flex items-center gap-2">📞 +91 99099 09090</p>
                </div>
            </div>

        </div>
    </section>

    <!-- PRODUCTS -->
    <section class="max-w-7xl mx-auto px-6 pb-20">
        <h2 class="text-3xl font-bold mb-10">Our Fertilizers</h2>

        <div class="grid md:grid-cols-3 gap-10">

            @foreach (var p in products)
            {
                <div class="
                        bg-white border rounded-3xl p-8 text-center
                        transition-all duration-500
                        hover:-translate-y-2
                        hover:shadow-[0_20px_50px_rgba(0,0,0,0.15)]
                        group
                    ">

                    <!-- IMAGE -->
                    <div class="bg-gray-50 rounded-2xl p-10 mb-6 overflow-hidden">
                        <img src="@p.Img"
                             alt="@p.Name"
                             class="
                                    h-40 mx-auto object-contain
                                    transition duration-500
                                    group-hover:scale-110
                                 " />
                    </div>

                    <!-- TITLE -->
                    <h3 class="font-bold mb-6 text-lg">@p.Name</h3>

                    <!-- BUTTON -->
                    <a href="/Shop/ProductDetails"
                       class="
                            inline-block bg-[#F2E8CF] px-8 py-3 rounded-full
                            text-xs uppercase tracking-widest
                            transition-all duration-300
                            hover:bg-yellow-500 hover:text-white hover:scale-105
                           ">
                        View Product
                    </a>

                </div>
            }

        </div>
    </section>

</div>