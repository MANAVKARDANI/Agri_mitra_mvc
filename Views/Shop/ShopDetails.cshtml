@{
    var shopName = ViewBag.ShopName;
    var shopImage = ViewBag.ShopImage;
    var shopAddress = ViewBag.ShopAddress;

    var products = new List<dynamic>
    {
        new { Name = "Imported Super Potash", Img = "/images/potash.png" },
        new { Name = "Urea Fertilizer", Img = "/images/UREA.png" },
        new { Name = "Bio DAP", Img = "/images/Bio dap.png" }
    };
}

<div class="bg-white">

    <!-- HERO -->
    <section class="relative">
        <div class="h-[350px]">
            <img src="@shopImage" class="w-full h-full object-cover" />

            <div class="absolute inset-0 bg-black/40"></div>

            <div class="absolute inset-0 flex items-center justify-center text-white">
                <h1 class="text-5xl font-bold">@shopName</h1>
            </div>
        </div>
    </section>

    <!-- INFO -->
    <section class="py-16 max-w-6xl mx-auto px-6">
        <h2 class="text-3xl font-bold mb-4">Shop Info</h2>
        <p class="text-gray-600">📍 @shopAddress</p>
    </section>

    <!-- PRODUCTS -->
    <section class="max-w-6xl mx-auto px-6 pb-20">
        <h2 class="text-2xl font-bold mb-8">Products</h2>

        <div class="grid md:grid-cols-3 gap-6">
            @foreach (var p in products)
            {
                <div class="border p-6 text-center rounded-xl">
                    <img src="@p.Img" class="h-32 mx-auto mb-4" />
                    <h3 class="font-bold">@p.Name</h3>
                </div>
            }
        </div>
    </section>
</div>