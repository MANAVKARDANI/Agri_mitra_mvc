@{
    ViewData["Title"] = "Product Details";

    var productName = "Potash";
    var price = 499;
    var stock = 23;
    var image = "https://lh3.googleusercontent.com/aida-public/AB6AXuC7Jm8GLbEwAHCTT_8QFWbEb-9R6T5YkKeffvSOw14l39IkP7IZZuvfcph_2ist3WMYtZ9-IvgF2A3XjpDKyP1GraRFvOd5eP_wtBNU3gJu1B18qUR4kNQ-ZMIlkGK09oLTTUwp2DgjFgsJO6cSC9Raw1o_qXbAff4YXonKVLIRRxeZZtu5vrKYRENB4NJirbI66WOVgm9Iinpdp4-y1FX8s1Vk_BR03Q-vIfY1KmMEWGetJIkANMqfVEJ9TYqQ8fveWlDBy09zBYF8";
}

<div class="bg-white text-slate-800 min-h-screen">

    <main class="py-20">
        <div class="max-w-7xl mx-auto px-6">

            <div class="flex flex-col md:flex-row gap-16">

                <!-- PRODUCT IMAGE -->
                <div class="w-full md:w-1/2">
                    <div class="bg-white rounded-3xl p-8 border border-gray-100 shadow-lg group">
                        <img src="@image"
                             alt="@productName"
                             class="w-full object-contain transition duration-500 group-hover:scale-105" />
                    </div>
                </div>

                <!-- PRODUCT DETAILS -->
                <div class="w-full md:w-1/2 flex flex-col justify-center">

                    <h1 class="text-5xl font-bold mb-4">@productName</h1>

                    <p class="text-2xl font-semibold text-gray-700 mb-6">
                        ₹@price.00
                    </p>

                    <p class="text-gray-500 leading-relaxed mb-10 text-sm">
                        Our professional-grade Potash fertilizer improves crop quality,
                        strengthens roots, and boosts plant immunity. Perfect for
                        farmers looking for better yield and soil health.
                    </p>

                    <!-- STOCK -->
                    <div class="flex items-center mb-8">
                        <span class="text-sm font-medium uppercase text-gray-500 mr-3">
                            Stock
                        </span>

                        <span class="font-bold text-lg">@stock</span>
                    </div>

                    <!-- QUANTITY -->
                    <div class="flex items-center gap-6 mb-10">
                        <div class="flex border border-gray-200 rounded-lg">

                            <button onclick="decrease()"
                                    class="px-4 py-2 text-lg hover:text-green-700">
                                -
                            </button>

                            <span id="qty" class="px-6 py-2 font-bold">1</span>

                            <button onclick="increase()"
                                    class="px-4 py-2 text-lg hover:text-green-700">
                                +
                            </button>

                        </div>
                    </div>

                    <!-- BUTTON -->
                    <a id="bookingBtn"
                       href="#"
                       class="w-full md:w-auto px-12 py-4 border-2 border-green-800 text-green-800 font-bold rounded-xl hover:bg-green-800 hover:text-white transition uppercase tracking-widest text-sm text-center">
                        Advance Booking
                    </a>

                </div>
            </div>

            <!-- INFO SECTION -->
            <div class="mt-28 border-t pt-16">
                <div class="bg-[#F9F9F7] rounded-3xl p-14">

                    <h2 class="text-4xl font-bold text-center mb-6">
                        AGRI-MITRA. We're here.
                    </h2>

                    <p class="text-center text-gray-500 max-w-xl mx-auto mb-12 text-sm">
                        Hello, we are AGRI-MITRA. Always beside you when you buy farm
                        products or sell. The best results for your harvest are just in sight.
                    </p>

                    <div class="grid md:grid-cols-2 gap-10">

                        <div>
                            <h4 class="font-bold text-lg mb-3">Office Location</h4>

                            <p class="text-gray-500 text-sm">
                                156 University Road <br />
                                Rajkot - 360005 <br />
                                Gujarat, India
                            </p>
                        </div>

                        <div>
                            <h4 class="font-bold text-lg mb-3">Get Updates</h4>

                            <div class="flex border-b border-gray-300 pb-2">
                                <input type="email"
                                       placeholder="Your email address"
                                       class="w-full bg-transparent outline-none text-sm" />

                                <button class="text-green-700 font-semibold">→</button>
                            </div>
                        </div>

                    </div>
                </div>
            </div>

        </div>
    </main>
</div>

<!-- JS FOR QUANTITY + BOOKING -->
<script>
    let quantity = 1;
    const stock = @stock;

    function increase() {
        if (quantity < stock) {
            quantity++;
            document.getElementById("qty").innerText = quantity;
        }
    }

    function decrease() {
        if (quantity > 1) {
            quantity--;
            document.getElementById("qty").innerText = quantity;
        }
    }

    document.getElementById("bookingBtn").addEventListener("click", function () {
        const url = `/Shop/Billing?name=@productName&price=@price&qty=${quantity}`;
        window.location.href = url;
    });
</script>