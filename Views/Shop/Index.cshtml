@model ShopViewModel

<div class="bg-white text-gray-800">

    <!-- HERO -->
    <section class="relative">
        <div class="h-[350px] bg-cover bg-center"
             style="background-image: url('/images/Hero_shop.png')">

            <div class="absolute inset-0 bg-black/40"></div>

            <div class="absolute inset-0 flex flex-col items-center justify-center text-white text-center">
                <h1 class="text-5xl font-extrabold">Explore Shops</h1>
                <p class="mt-2 text-lg text-white/90">
                    Find premium stockists near you
                </p>
            </div>
        </div>
    </section>

    <!-- SHOP GRID -->
    <section class="py-16 bg-[#F5F5F3]">
        <div class="max-w-7xl mx-auto px-6">

            <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-8">

                @foreach (var shop in Model.Shops)
                {
                    <div class="relative bg-[#EFEFEF] rounded-2xl p-4
                        transition-all duration-500 ease-[cubic-bezier(.25,.8,.25,1)]
                        hover:-translate-y-3 hover:shadow-[0_20px_60px_rgba(0,0,0,0.25)]
                        hover:shadow-green-200/50
                        group cursor-pointer overflow-hidden">

                        <!-- Gradient Glow -->
                        <div class="absolute inset-0 opacity-0 group-hover:opacity-100 transition duration-500
                            bg-gradient-to-br from-green-100/40 via-transparent to-yellow-100/40"></div>

                        <!-- IMAGE -->
                        <div class="relative rounded-xl overflow-hidden">
                            <img src="@shop.Image"
                                 class="w-full h-48 object-cover transition-transform duration-700 group-hover:scale-110" />

                            @if (shop.Verified)
                            {
                                <div class="absolute top-3 right-3 bg-white text-green-700 text-xs px-3 py-1 rounded-full shadow-md">
                                    Verified
                                </div>
                            }
                        </div>

                        <!-- TEXT -->
                        <div class="mt-4 relative z-10">
                            <h3 class="font-bold text-lg text-gray-800 group-hover:text-green-800 transition">
                                @shop.Name
                            </h3>

                            <p class="text-sm text-gray-500 mt-1">@shop.Address</p>

                            <a asp-controller="Shop"
                               asp-action="Details"
                               asp-route-id="@shop.Id"
                               class="inline-flex items-center gap-1 text-green-700 font-semibold text-sm mt-4
                                   transition-all duration-300 group-hover:gap-3">
                                VIEW DETAILS
                                <span class="material-symbols-outlined text-[16px] group-hover:translate-x-1 transition">
                                    arrow_forward
                                </span>
                            </a>
                        </div>
                    </div>
                }

            </div>

            <!-- PAGINATION -->
            <div class="flex justify-center mt-12 gap-3">

                @for (int i = 1; i <= Model.TotalPages; i++)
                {
                    <a asp-action="Index" asp-route-page="@i"
                       class="px-4 py-2 rounded-md transition @(Model.CurrentPage == i
                                               ? "bg-green-700 text-white"
                                               : "bg-white border hover:bg-gray-100")">
                    @i
                </a>
                                }

            </div>

        </div>
    </section>

</div>