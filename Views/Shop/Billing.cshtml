@{
    ViewData["Title"] = "Billing";

    var name = ViewBag.Name ?? "Potash";
    var price = ViewBag.Price ?? 499;
    var qty = ViewBag.Quantity ?? 1;

    var subtotal = price * qty;
    var tax = subtotal * 0.05;
    var total = subtotal + tax;
}

<div class="bg-[#F9FAFB] min-h-screen py-16">

    <div class="max-w-7xl mx-auto px-6">

        <div class="grid lg:grid-cols-3 gap-10">

            <!-- ================= BILLING FORM ================= -->
            <div class="lg:col-span-2 bg-white rounded-2xl shadow-sm border p-8">

                <h2 class="text-xl font-bold mb-8">Billing Details</h2>

                <form onsubmit="handleSubmit(event)" class="space-y-6">

                    <!-- NAME + PHONE -->
                    <div class="grid md:grid-cols-2 gap-6">

                        <div>
                            <label class="text-sm text-gray-500">Full Name</label>
                            <input required type="text"
                                   placeholder="John Doe"
                                   class="mt-2 w-full border rounded-lg px-4 py-3 focus:ring-2 focus:ring-green-700 outline-none" />
                        </div>

                        <div>
                            <label class="text-sm text-gray-500">Phone Number</label>
                            <input required type="tel"
                                   placeholder="+91 98765 43210"
                                   class="mt-2 w-full border rounded-lg px-4 py-3 focus:ring-2 focus:ring-green-700 outline-none" />
                        </div>

                    </div>

                    <!-- ADDRESS -->
                    <div>
                        <label class="text-sm text-gray-500">Shipping Address</label>

                        <textarea required rows="3"
                                  placeholder="Street address, City, State, ZIP"
                                  class="mt-2 w-full border rounded-lg px-4 py-3 focus:ring-2 focus:ring-green-700 outline-none"></textarea>
                    </div>

                    <!-- PAYMENT -->
                    <div>
                        <label class="text-sm text-gray-600">Payment Method</label>

                        <div class="grid md:grid-cols-3 gap-4 mt-4">

                            <label class="border rounded-lg p-4 flex items-center gap-2 cursor-pointer payment-option active" data-type="UPI">
                                <input type="radio" name="payment" checked />
                                UPI
                            </label>

                            <label class="border rounded-lg p-4 flex items-center gap-2 cursor-pointer payment-option" data-type="Card">
                                <input type="radio" name="payment" />
                                Card
                            </label>

                            <label class="border rounded-lg p-4 flex items-center gap-2 cursor-pointer payment-option" data-type="Cash">
                                <input type="radio" name="payment" />
                                Cash
                            </label>

                        </div>
                    </div>

                </form>

            </div>

            <!-- ================= ORDER SUMMARY ================= -->
            <div class="bg-white rounded-2xl shadow-sm border p-8 h-fit">

                <h2 class="text-lg font-bold mb-6">Order Summary</h2>

                <div class="space-y-4 text-sm">

                    <div class="flex justify-between">
                        <div>
                            <p class="font-medium">@name</p>
                            <p class="text-gray-400">Qty: @qty</p>
                        </div>

                        <p>Rs. @price</p>
                    </div>

                    <hr />

                    <div class="flex justify-between">
                        <p class="text-gray-500">Subtotal</p>
                        <p>Rs. @subtotal.ToString("0.00")</p>
                    </div>

                    <div class="flex justify-between">
                        <p class="text-gray-500">Tax (GST 5%)</p>
                        <p>Rs. @tax.ToString("0.00")</p>
                    </div>

                    <div class="flex justify-between font-semibold text-lg">
                        <p>Total</p>
                        <p class="text-yellow-600">Rs. @total.ToString("0.00")</p>
                    </div>

                </div>

                <button onclick="handleSubmit(event)"
                        class="w-full mt-8 bg-[#111827] text-white py-4 rounded-xl font-semibold hover:bg-black transition">
                    Confirm & Pay →
                </button>

                <p class="text-xs text-gray-400 text-center mt-4">
                    Secure SSL Encrypted Payment
                </p>

            </div>

        </div>

        <!-- ================= INFO SECTION ================= -->
        <div class="mt-24">

            <div class="bg-[#EEF0F2] rounded-3xl p-14 text-center">

                <h2 class="text-3xl font-bold mb-4">
                    AGRI-MITRA . We're here.
                </h2>

                <p class="text-gray-500 text-sm max-w-xl mx-auto mb-12">
                    Hello, we are AGRI-MITRA. Always beside you when you buy farm
                    products or sell. The best results for your harvest are just in sight.
                </p>

                <div class="grid md:grid-cols-2 gap-10 text-left">

                    <div>
                        <h4 class="font-semibold mb-2">Office Location</h4>

                        <p class="text-gray-500 text-sm">
                            156 University Road <br />
                            Rajkot - 360005 <br />
                            Gujarat, India
                        </p>
                    </div>

                    <div>
                        <h4 class="font-semibold mb-2">Get Updates</h4>

                        <div class="flex border-b pb-2">
                            <input placeholder="Your email address"
                                   class="bg-transparent outline-none w-full text-sm" />

                            <button class="text-green-700 font-semibold">→</button>
                        </div>
                    </div>

                </div>

            </div>

        </div>

    </div>
</div>

<!-- ================= JS ================= -->
<script>
    // PAYMENT SELECTION
    const options = document.querySelectorAll(".payment-option");

    options.forEach(opt => {
        opt.addEventListener("click", () => {
            options.forEach(o => o.classList.remove("border-green-700", "bg-green-50"));
            opt.classList.add("border-green-700", "bg-green-50");

            opt.querySelector("input").checked = true;
        });
    });

    // SUBMIT
    function handleSubmit(e) {
        e.preventDefault();
        alert("Payment Successful!");
    }
</script>