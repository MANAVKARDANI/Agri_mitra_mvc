@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="p-6 space-y-8 bg-gray-50 min-h-screen">

    <!-- HEADER -->
    <div class="flex justify-between items-center">
        <div>
            <h1 class="text-2xl font-bold text-gray-800">All Fertilizers</h1>
            <p class="text-sm text-gray-500">
                Manage and track your agricultural supply stock across all suppliers.
            </p>
        </div>

        <a asp-action="AddFertilizer" asp-controller="Admin"
           class="bg-green-700 hover:bg-green-800 text-white px-4 py-2 rounded-lg text-sm">
            ➕ Add New Fertilizer
        </a>
    </div>

    <!-- STATS -->
    <div class="grid md:grid-cols-3 gap-6">

        <div class="bg-white p-6 rounded-xl border shadow-sm">
            <p class="text-sm text-gray-500">Total Stock</p>
            <h2 class="text-2xl font-bold">350 Units</h2>
            <p class="text-green-600 text-xs mt-2">+12%</p>
        </div>

        <div class="bg-white p-6 rounded-xl border shadow-sm">
            <p class="text-sm text-gray-500">Low Stock</p>
            <h2 class="text-2xl font-bold">2 Items</h2>
        </div>

        <div class="bg-white p-6 rounded-xl border shadow-sm">
            <p class="text-sm text-gray-500">Suppliers</p>
            <h2 class="text-2xl font-bold">12</h2>
        </div>

    </div>

    <!-- TABLE -->
    <div class="bg-white border rounded-xl overflow-hidden">

        <table class="w-full text-sm">
            <thead class="bg-green-50 text-xs uppercase">
                <tr>
                    <th class="p-4 text-left">Name</th>
                    <th>Supplier</th>
                    <th>Price</th>
                    <th>Stock</th>
                    <th>Status</th>
                    <th>Actions</th>
                </tr>
            </thead>

            <tbody>

                <tr class="border-t">
                    <td class="p-4">Urea Fertilizer</td>
                    <td>Green Agro</td>
                    <td>₹500</td>
                    <td><span class="bg-green-100 px-2 py-1 rounded">200</span></td>
                    <td class="text-green-600">High</td>
                    <td>✏️ 🗑️</td>
                </tr>

                <tr class="border-t">
                    <td class="p-4">Organic Compost</td>
                    <td>Organic Hub</td>
                    <td>₹800</td>
                    <td><span class="bg-yellow-100 px-2 py-1 rounded">150</span></td>
                    <td class="text-yellow-600">Medium</td>
                    <td>✏️ 🗑️</td>
                </tr>

                <tr class="border-t">
                    <td class="p-4">Liquid Nitrogen</td>
                    <td>Chemical Pros</td>
                    <td>₹1200</td>
                    <td><span class="bg-red-100 px-2 py-1 rounded">12</span></td>
                    <td class="text-red-600">Low</td>
                    <td>✏️ 🗑️</td>
                </tr>

            </tbody>
        </table>

        <div class="p-4 text-sm text-gray-500">
            Showing 3 items
        </div>

    </div>

</div>