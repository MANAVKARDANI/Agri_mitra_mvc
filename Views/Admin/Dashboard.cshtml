@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";

    var chartData = new int[] { 40, 70, 35, 95, 60, 75, 50 };
    var days = new string[] { "MON", "TUE", "WED", "THU", "FRI", "SAT", "SUN" };
}

<!-- LUCIDE ICON CDN -->
<script src="https://unpkg.com/lucide@latest"></script>

<div class="space-y-8">

    <!-- ================= STATS ================= -->
    <div class="grid md:grid-cols-3 gap-6">

        <!-- Suppliers -->
        <div class="bg-white p-6 rounded-xl border shadow-sm">
            <div class="flex justify-between mb-4">
                <div class="bg-green-100 p-3 rounded-lg text-green-700">
                    <i data-lucide="store"></i>
                </div>

                <span class="text-green-600 text-xs bg-green-100 px-2 py-1 rounded">
                    +12%
                </span>
            </div>

            <p class="text-gray-500 text-sm">Total Suppliers</p>
            <h2 class="text-3xl font-bold mt-1">125</h2>

            <div class="w-full bg-gray-200 h-2 rounded mt-4">
                <div class="bg-green-700 h-2 rounded w-3/4"></div>
            </div>
        </div>

        <!-- Fertilizers -->
        <div class="bg-white p-6 rounded-xl border shadow-sm">
            <div class="flex justify-between mb-4">
                <div class="bg-green-100 p-3 rounded-lg text-green-700">
                    <i data-lucide="flask-conical"></i>
                </div>

                <span class="text-green-600 text-xs bg-green-100 px-2 py-1 rounded">
                    +5%
                </span>
            </div>

            <p class="text-gray-500 text-sm">Total Fertilizers</p>
            <h2 class="text-3xl font-bold mt-1">320</h2>

            <div class="w-full bg-gray-200 h-2 rounded mt-4">
                <div class="bg-green-700 h-2 rounded w-2/3"></div>
            </div>
        </div>

        <!-- Users -->
        <div class="bg-white p-6 rounded-xl border shadow-sm">
            <div class="flex justify-between mb-4">
                <div class="bg-blue-100 p-3 rounded-lg text-blue-600">
                    <i data-lucide="users"></i>
                </div>

                <span class="text-blue-600 text-xs bg-blue-100 px-2 py-1 rounded">
                    +18%
                </span>
            </div>

            <p class="text-gray-500 text-sm">Total Users</p>
            <h2 class="text-3xl font-bold mt-1">500+</h2>

            <div class="w-full bg-gray-200 h-2 rounded mt-4">
                <div class="bg-blue-500 h-2 rounded w-5/6"></div>
            </div>
        </div>

    </div>

    <!-- ================= QUICK ACTIONS ================= -->
    <div>
        <h2 class="text-xl font-semibold">Quick Actions</h2>

        <p class="text-gray-500 text-sm mb-6">
            Efficiently manage your day-to-day operations
        </p>

        <div class="grid md:grid-cols-4 gap-6">

            <div class="bg-white p-6 rounded-xl border shadow-sm hover:shadow-md transition cursor-pointer">
                <div class="bg-green-100 p-3 w-fit rounded-lg text-green-700 mb-4">
                    <i data-lucide="user-plus"></i>
                </div>
                <h3 class="font-semibold">Add Suppliers</h3>
                <p class="text-sm text-gray-500">
                    Register a new retail partner to the network
                </p>
            </div>

            <div class="bg-white p-6 rounded-xl border shadow-sm hover:shadow-md transition cursor-pointer">
                <div class="bg-green-100 p-3 w-fit rounded-lg text-green-700 mb-4">
                    <i data-lucide="package"></i>
                </div>
                <h3 class="font-semibold">Manage Fertilizers</h3>
                <p class="text-sm text-gray-500">
                    Update catalog pricing and stock levels
                </p>
            </div>

            <div class="bg-white p-6 rounded-xl border shadow-sm hover:shadow-md transition cursor-pointer">
                <div class="bg-green-100 p-3 w-fit rounded-lg text-green-700 mb-4">
                    <i data-lucide="clipboard-list"></i>
                </div>
                <h3 class="font-semibold">View All Orders</h3>
                <p class="text-sm text-gray-500">
                    Monitor and process recent customer orders
                </p>
            </div>

            <div class="bg-white p-6 rounded-xl border shadow-sm hover:shadow-md transition cursor-pointer">
                <div class="bg-green-100 p-3 w-fit rounded-lg text-green-700 mb-4">
                    <i data-lucide="users"></i>
                </div>
                <h3 class="font-semibold">View All Users</h3>
                <p class="text-sm text-gray-500">
                    Access and manage the user database
                </p>
            </div>

        </div>
    </div>

    <!-- ================= CHART + SHOPS ================= -->
    <div class="grid md:grid-cols-3 gap-6">

        <!-- CHART -->
        <div class="md:col-span-2 bg-white p-6 rounded-2xl border shadow-sm">
            <div class="flex justify-between items-center mb-6">
                <h3 class="font-semibold text-gray-800">
                    Order Trend Activity
                </h3>

                <span class="text-xs bg-gray-100 px-3 py-1 rounded-md text-gray-600">
                    Last 7 Days
                </span>
            </div>

            <div class="bg-gray-100 rounded-2xl p-8">
                <div class="flex items-end justify-between h-48">

                    @for (int i = 0; i < chartData.Length; i++)
                    {
                        <div class="flex flex-col items-center gap-3">
                            <div class="w-10 rounded-lg @(i == 3 ? "bg-green-700" : "bg-green-300") hover:scale-105 transition"
                                 style="height:@(chartData[i])px"></div>

                            <span class="text-xs text-gray-400 font-medium">
                                @days[i]
                            </span>
                        </div>
                    }

                </div>
            </div>
        </div>

        <!-- SHOPS -->
        <div class="bg-white p-6 rounded-xl border shadow-sm">
            <h3 class="font-semibold mb-5">Latest Registered Shops</h3>

            <ul class="space-y-5 text-sm">
                <li>
                    <p class="font-semibold">Green Valley Agri</p>
                    <span class="text-gray-500 text-xs">
                        2 hours ago • Punjab
                    </span>
                </li>

                <li>
                    <p class="font-semibold">Farming First Co.</p>
                    <span class="text-gray-500 text-xs">
                        5 hours ago • California
                    </span>
                </li>

                <li>
                    <p class="font-semibold">Nature's Best Ltd</p>
                    <span class="text-gray-500 text-xs">
                        1 day ago • Tuscany
                    </span>
                </li>
            </ul>

            <button class="mt-6 w-full bg-gray-100 hover:bg-gray-200 text-sm py-2 rounded-lg">
                VIEW ALL SHOPS
            </button>
        </div>

    </div>

</div>

<script>
    lucide.createIcons();
</script>