@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="p-6 bg-gray-50 min-h-screen space-y-8">

    <!-- HEADER -->
    <div>
        <h1 class="text-2xl font-bold text-gray-800">Admin Profile</h1>
        <p class="text-sm text-gray-500">
            Manage your personal information and account settings.
        </p>
    </div>

    <!-- PROFILE CARD -->
    <div class="bg-white rounded-2xl shadow-sm p-6 flex items-center gap-6">

        <!-- PROFILE IMAGE -->
        <div class="w-24 h-24 rounded-full bg-green-100 flex items-center justify-center text-green-700 text-2xl font-bold">
            MK
        </div>

        <!-- DETAILS -->
        <div class="flex-1">
            <h2 class="text-xl font-semibold text-gray-800">Manav Kardani</h2>
            <p class="text-gray-500 text-sm">Administrator</p>

            <div class="flex gap-4 mt-3 text-sm text-gray-500">
                <span>📧 manav@email.com</span>
                <span>📞 +91 9876543210</span>
            </div>
        </div>

        <!-- EDIT BUTTON -->
        <button class="bg-green-700 hover:bg-green-800 text-white px-4 py-2 rounded-lg text-sm shadow">
            ✏️ Edit Profile
        </button>

    </div>

    <!-- GRID SECTION -->
    <div class="grid md:grid-cols-3 gap-6">

        <!-- ACCOUNT DETAILS -->
        <div class="md:col-span-2 bg-white p-6 rounded-xl border shadow-sm">

            <h3 class="font-semibold text-gray-800 mb-4">Account Information</h3>

            <div class="grid grid-cols-2 gap-4">

                <div>
                    <label class="text-sm text-gray-500">Full Name</label>
                    <input value="Manav Kardani" class="w-full mt-1 p-2 border rounded-lg bg-gray-50" />
                </div>

                <div>
                    <label class="text-sm text-gray-500">Email</label>
                    <input value="manav@email.com" class="w-full mt-1 p-2 border rounded-lg bg-gray-50" />
                </div>

                <div>
                    <label class="text-sm text-gray-500">Phone</label>
                    <input value="+91 9876543210" class="w-full mt-1 p-2 border rounded-lg bg-gray-50" />
                </div>

                <div>
                    <label class="text-sm text-gray-500">Role</label>
                    <input value="Admin" disabled class="w-full mt-1 p-2 border rounded-lg bg-gray-100" />
                </div>

            </div>

            <!-- SAVE BUTTON -->
            <div class="mt-6 text-right">
                <button class="bg-green-700 text-white px-6 py-2 rounded-lg hover:bg-green-800">
                    Save Changes
                </button>
            </div>

        </div>

        <!-- ACTIVITY / STATS -->
        <div class="bg-white p-6 rounded-xl border shadow-sm">

            <h3 class="font-semibold text-gray-800 mb-4">Account Stats</h3>

            <div class="space-y-4 text-sm">

                <div class="flex justify-between">
                    <span class="text-gray-500">Total Shops Managed</span>
                    <span class="font-semibold">24</span>
                </div>

                <div class="flex justify-between">
                    <span class="text-gray-500">Fertilizers Listed</span>
                    <span class="font-semibold">42</span>
                </div>

                <div class="flex justify-between">
                    <span class="text-gray-500">Orders Processed</span>
                    <span class="font-semibold">128</span>
                </div>

            </div>

            <!-- PROGRESS -->
            <div class="mt-6">
                <p class="text-xs text-gray-500 mb-2">Profile Completion</p>

                <div class="w-full bg-gray-200 h-2 rounded">
                    <div class="bg-green-700 h-2 rounded w-4/5"></div>
                </div>

                <p class="text-xs text-gray-400 mt-1">80% Completed</p>
            </div>

        </div>

    </div>

    <!-- SECURITY -->
    <div class="bg-white p-6 rounded-xl border shadow-sm">

        <h3 class="font-semibold text-gray-800 mb-4">Security Settings</h3>

        <div class="grid md:grid-cols-2 gap-6">

            <div>
                <label class="text-sm text-gray-500">Current Password</label>
                <input type="password" class="w-full mt-1 p-2 border rounded-lg bg-gray-50" />
            </div>

            <div>
                <label class="text-sm text-gray-500">New Password</label>
                <input type="password" class="w-full mt-1 p-2 border rounded-lg bg-gray-50" />
            </div>

        </div>

        <div class="mt-6 text-right">
            <button class="bg-red-500 text-white px-6 py-2 rounded-lg hover:bg-red-600">
                Update Password
            </button>
        </div>

    </div>

</div>