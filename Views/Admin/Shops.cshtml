@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";

    var shops = new[]
    {
        new { Name="Green Agro", Location="India", Phone="+91 9870543210", Hours="9 AM - 6 PM", Icon="truck" },
        new { Name="Organic Hub", Location="India", Phone="+91 8765432109", Hours="10 AM - 7 PM", Icon="leaf" },
        new { Name="Punjab Seeds & Co", Location="Punjab, India", Phone="+91 9123456780", Hours="8 AM - 8 PM", Icon="store" }
    };
}

<!-- LUCIDE -->
<script src="https://unpkg.com/lucide@latest"></script>

<div class="p-6 space-y-8 bg-gray-50 min-h-screen">

    <!-- ================= HEADER ================= -->
    <div class="flex justify-between items-center">
        <div>
            <h1 class="text-2xl font-bold text-gray-800">Manage Shops</h1>
            <p class="text-sm text-gray-500">
                Register and monitor fertilizer distribution centers across regions.
            </p>
        </div>

        <a href="/Admin/AddShop"
           class="flex items-center gap-2 bg-green-700 hover:bg-green-800 text-white px-4 py-2 rounded-lg text-sm shadow">
            <i data-lucide="plus"></i>
            Add New Shop
        </a>
    </div>

    <!-- ================= STATS ================= -->
    <div class="grid md:grid-cols-3 gap-6">

        <div class="bg-white border rounded-xl p-6 flex items-center gap-4 shadow-sm">
            <div class="bg-green-100 p-3 rounded-lg text-green-700">
                <i data-lucide="store"></i>
            </div>
            <div>
                <p class="text-xs text-gray-500 uppercase">TOTAL SHOPS</p>
                <h2 class="text-xl font-bold">24</h2>
            </div>
        </div>

        <div class="bg-white border rounded-xl p-6 flex items-center gap-4 shadow-sm">
            <div class="bg-blue-100 p-3 rounded-lg text-blue-600">
                <i data-lucide="map"></i>
            </div>
            <div>
                <p class="text-xs text-gray-500 uppercase">ACTIVE REGIONS</p>
                <h2 class="text-xl font-bold">12</h2>
            </div>
        </div>

        <div class="bg-white border rounded-xl p-6 flex items-center gap-4 shadow-sm">
            <div class="bg-yellow-100 p-3 rounded-lg text-yellow-600">
                <i data-lucide="shield-check"></i>
            </div>
            <div>
                <p class="text-xs text-gray-500 uppercase">VERIFIED PARTNERS</p>
                <h2 class="text-xl font-bold">18</h2>
            </div>
        </div>

    </div>

    <!-- ================= SEARCH ================= -->
    <div class="bg-white border rounded-xl p-4 flex justify-between items-center shadow-sm">

        <div class="flex items-center gap-2 w-1/2">
            <i data-lucide="search" class="text-gray-400"></i>
            <input placeholder="Search shops by name, location..."
                   class="outline-none text-sm w-full" />
        </div>

        <div class="flex gap-3">

            <button class="flex items-center gap-2 border px-3 py-2 rounded-lg text-sm hover:bg-gray-100">
                <i data-lucide="filter"></i>
                Filter
            </button>

            <button class="flex items-center gap-2 border px-3 py-2 rounded-lg text-sm hover:bg-gray-100">
                <i data-lucide="download"></i>
                Export
            </button>

        </div>

    </div>

    <!-- ================= TABLE ================= -->
    <div class="bg-white border rounded-xl overflow-hidden shadow-sm">

        <table class="w-full text-sm">
            <thead class="bg-gray-100 text-gray-600 text-xs uppercase">
                <tr>
                    <th class="p-4 text-left">Shop Name</th>
                    <th class="text-left">Location</th>
                    <th class="text-left">Contact Number</th>
                    <th class="text-left">Business Hours</th>
                    <th class="text-left">Actions</th>
                </tr>
            </thead>

            <tbody>
                @foreach (var shop in shops)
                {
                    <tr class="border-t hover:bg-gray-50">

                        <!-- NAME -->
                        <td class="p-4">
                            <div class="flex items-center gap-3">
                                <div class="bg-green-100 p-2 rounded-lg">
                                    <i data-lucide="@shop.Icon" class="text-green-700"></i>
                                </div>
                                <span class="font-medium">@shop.Name</span>
                            </div>
                        </td>

                        <!-- LOCATION -->
                        <td class="text-gray-600">
                            <div class="flex items-center gap-2">
                                <i data-lucide="map-pin"></i>
                                @shop.Location
                            </div>
                        </td>

                        <!-- PHONE -->
                        <td class="text-gray-700">@shop.Phone</td>

                        <!-- HOURS -->
                        <td>
                            <span class="bg-gray-100 px-3 py-1 rounded text-xs">
                                @shop.Hours
                            </span>
                        </td>

                        <!-- ACTIONS -->
                        <td>
                            <div class="flex gap-3 text-gray-500">
                                <button class="hover:text-blue-600">
                                    <i data-lucide="pencil"></i>
                                </button>

                                <button class="hover:text-red-600">
                                    <i data-lucide="trash-2"></i>
                                </button>
                            </div>
                        </td>

                    </tr>
                }
            </tbody>
        </table>

        <!-- ================= PAGINATION ================= -->
        <div class="flex justify-between items-center p-4 text-sm text-gray-500">

            <span>SHOWING 1-3 OF 24 SHOPS</span>

            <div class="flex gap-2 items-center">
                <button class="px-3 py-1 border rounded">&lt;</button>

                <button class="px-3 py-1 bg-green-700 text-white rounded">1</button>
                <button class="px-3 py-1 border rounded">2</button>
                <button class="px-3 py-1 border rounded">3</button>

                <button class="px-3 py-1 border rounded">&gt;</button>
            </div>

        </div>
    </div>

    <!-- ================= PROMO ================= -->
    <div class="bg-gradient-to-r from-green-800 to-green-500 text-white rounded-xl p-6">

        <h3 class="text-lg font-semibold mb-2">
            Need to expand your shop network?
        </h3>

        <p class="text-sm text-green-100">
            Manage multi-store inventory sync and regional tax settings
            automatically through our Premium Shop Expansion toolkit.
        </p>

    </div>

</div>

<script>
    lucide.createIcons();
</script>