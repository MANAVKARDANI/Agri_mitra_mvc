@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="p-6 space-y-6 bg-gray-50 min-h-screen">

    <!-- HEADER -->
    <div class="flex justify-between items-center">

        <div>
            <h1 class="text-2xl font-bold text-gray-800">Orders</h1>

            <p class="text-sm text-gray-500">
                Manage and track all customer fertilizer orders in one place.
            </p>
        </div>

        <div class="flex gap-3">

            <button class="flex items-center gap-2 border px-4 py-2 rounded-lg text-sm hover:bg-gray-100">
                ⬇️ Export CSV
            </button>

            <button class="flex items-center gap-2 border px-4 py-2 rounded-lg text-sm hover:bg-gray-100">
                ⚙️ Filter
            </button>

        </div>

    </div>

    <!-- TABLE -->
    <div class="bg-white border rounded-xl overflow-hidden shadow-sm">

        <table class="w-full text-sm">

            <!-- HEAD -->
            <thead class="bg-green-50 text-green-700 text-xs uppercase">
                <tr>
                    <th class="p-4 text-left">Date</th>
                    <th class="text-left">Customer</th>
                    <th class="text-left">Product</th>
                    <th class="text-left">Price</th>
                    <th class="text-left">Quantity</th>
                    <th class="text-left">Status</th>
                    <th class="text-left">Actions</th>
                </tr>
            </thead>

            <!-- BODY -->
            <tbody>

                <!-- ROW 1 -->
                <tr class="border-t hover:bg-gray-50">

                    <td class="p-4 text-gray-600">12-Feb-2025</td>

                    <td class="flex items-center gap-3 p-4">
                        <div class="w-8 h-8 rounded-full bg-green-100 text-green-700 flex items-center justify-center text-xs font-semibold">
                            RP
                        </div>
                        Raj Patel
                    </td>

                    <td class="text-gray-700">Urea Fertilizer</td>

                    <td class="font-semibold">₹500</td>

                    <td>5</td>

                    <td>
                        <span class="bg-yellow-100 text-yellow-700 text-xs px-3 py-1 rounded-full">
                            ● Not Collected
                        </span>
                    </td>

                    <td>
                        <button class="text-gray-400 hover:text-gray-600">⋮</button>
                    </td>

                </tr>

                <!-- ROW 2 -->
                <tr class="border-t hover:bg-gray-50">

                    <td class="p-4 text-gray-600">10-Feb-2025</td>

                    <td class="flex items-center gap-3 p-4">
                        <div class="w-8 h-8 rounded-full bg-green-100 text-green-700 flex items-center justify-center text-xs font-semibold">
                            MS
                        </div>
                        Meera Shah
                    </td>

                    <td>Organic Compost</td>

                    <td class="font-semibold">₹800</td>

                    <td>2</td>

                    <td>
                        <span class="bg-green-100 text-green-700 text-xs px-3 py-1 rounded-full">
                            ● Collected
                        </span>
                    </td>

                    <td>
                        <button class="text-gray-400 hover:text-gray-600">⋮</button>
                    </td>

                </tr>

                <!-- ROW 3 -->
                <tr class="border-t hover:bg-gray-50">

                    <td class="p-4 text-gray-600">09-Feb-2025</td>

                    <td class="flex items-center gap-3 p-4">
                        <div class="w-8 h-8 rounded-full bg-green-100 text-green-700 flex items-center justify-center text-xs font-semibold">
                            AV
                        </div>
                        Aman Verma
                    </td>

                    <td>NPK Mix</td>

                    <td class="font-semibold">₹750</td>

                    <td>3</td>

                    <td>
                        <span class="bg-yellow-100 text-yellow-700 text-xs px-3 py-1 rounded-full">
                            ● Not Collected
                        </span>
                    </td>

                    <td>
                        <button class="text-gray-400 hover:text-gray-600">⋮</button>
                    </td>

                </tr>

            </tbody>

        </table>

        <!-- PAGINATION -->
        <div class="flex justify-between items-center p-4 text-sm text-gray-500">

            <span>Showing 3 of 12 orders</span>

            <div class="flex gap-2 items-center">

                <button class="px-3 py-1 border rounded">&lt;</button>

                <button class="px-3 py-1 bg-green-700 text-white rounded">1</button>

                <button class="px-3 py-1 border rounded">2</button>

                <button class="px-3 py-1 border rounded">3</button>

                <button class="px-3 py-1 border rounded">&gt;</button>

            </div>

        </div>

    </div>

</div>