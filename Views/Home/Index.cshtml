@model HomeViewModel
@{
    ViewData["Title"] = "Home";
}

<script src="https://cdn.tailwindcss.com"></script>

<div class="bg-white text-gray-800">

    <!-- HERO -->
    <section class="relative h-[600px] flex items-center">
        <div class="absolute inset-0">
            <img src="~/images/Hero.png" class="w-full h-full object-cover" />
            <div class="absolute inset-0 bg-white/20"></div>
        </div>

        <div class="relative max-w-7xl mx-auto px-6 w-full">
            <div class="max-w-xl bg-white/40 backdrop-blur-xl p-10 rounded-3xl shadow-2xl">

                <span class="bg-green-100 text-green-800 text-xs px-4 py-1 rounded-full">
                    Real-time Stock Alerts
                </span>

                <h1 class="text-5xl font-extrabold text-green-900 mt-6">
                    Smart Farming <br />
                    <span class="text-gray-700 font-light">Redefined.</span>
                </h1>

                <p class="mt-6 text-gray-600">
                    Access premium fertilizers and real-time inventory data.
                </p>

                <div class="mt-8 flex gap-4">
                    <a href="/Shop/Index"
                       class="bg-green-800 text-white px-6 py-3 rounded-lg">
                        Explore Products
                    </a>

                    <a href="/Shop/Index"
                       class="border px-6 py-3 rounded-lg text-green-800">
                        Locate Shops
                    </a>
                </div>

            </div>
        </div>
    </section>

    <!-- PRODUCTS -->
    <section class="py-24 bg-gray-50">
        <div class="max-w-7xl mx-auto px-6">

            <h2 class="text-4xl font-bold mb-10">Essential Nutrients</h2>

            <div class="grid grid-cols-1 md:grid-cols-3 gap-10">

                @foreach (var item in Model.Products)
                {
                    <div class="bg-[#F4F4F1] rounded-[40px] p-10 text-center">

                        <img src="@item.Image" class="h-64 mx-auto mb-6" />

                        <h3 class="text-2xl font-bold">@item.Title</h3>
                        <p class="text-gray-500">@item.Description</p>

                    </div>
                }

            </div>
        </div>
    </section>

    <!-- FEATURED -->
    <section class="py-24 bg-[#F5F5F5]">
        <div class="max-w-7xl mx-auto px-6 text-center">

            <h2 class="text-3xl font-bold">Featured Selection</h2>

            <div class="grid grid-cols-2 md:grid-cols-4 gap-8 mt-14">

                @foreach (var item in Model.FeaturedProducts)
                {
                    <div class="bg-white p-6 rounded-xl shadow">

                        <img src="@item.Image" class="h-20 mx-auto" />

                        <h3 class="mt-4 font-semibold">@item.Name</h3>
                        <p class="text-sm text-gray-400">@item.Description</p>

                    </div>
                }

            </div>

        </div>
    </section>

</div>