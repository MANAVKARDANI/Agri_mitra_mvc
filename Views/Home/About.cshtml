@{
    ViewData["Title"] = "About";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="bg-[#F5F5F3] text-slate-800 overflow-hidden">

    <!-- HERO -->
    <section class="relative">
        <div class="h-[350px] w-full relative group overflow-hidden">

            <img src="~/images/Hero_shop.png"
                 alt="Agri Mitra"
                 class="w-full h-full object-cover transition duration-700 group-hover:scale-105" />

            <div class="absolute inset-0 bg-black/30"></div>

            <div class="absolute inset-0 flex flex-col justify-center items-center text-center">
                <span class="material-symbols-outlined text-white text-5xl mb-4">
                    spa
                </span>

                <h1 class="text-5xl font-extrabold text-white mb-2">
                    About Us
                </h1>

                <p class="text-white/90 text-sm tracking-widest uppercase">
                    Home &gt; About
                </p>
            </div>

            <span class="material-symbols-outlined absolute left-10 top-20 text-white/30 text-7xl animate-bounce">
                eco
            </span>

            <span class="material-symbols-outlined absolute right-10 bottom-20 text-white/30 text-6xl animate-pulse">
                auto_awesome
            </span>

        </div>
    </section>

    <!-- INTRO -->
    <section class="py-20">
        <div class="max-w-4xl mx-auto text-center px-6">

            <h2 class="text-5xl font-black mb-8 hover:text-green-700 transition">
                About Us
            </h2>

            <p class="text-slate-600 text-lg leading-relaxed hover:text-slate-800 transition">
                At Agri-Mitra we provide smart fertilizer solutions that help
                farmers grow healthier crops and increase productivity. Our mission
                is to bridge the gap between modern agricultural science and
                real-world farming needs while promoting sustainable soil health.
            </p>

        </div>
    </section>

    <!-- VALUES -->
    <section class="py-20">
        <div class="max-w-6xl mx-auto px-6 space-y-32">

            <!-- MISSION -->
            <div class="flex flex-col md:flex-row items-center gap-16">

                <div class="md:w-1/2 relative">

                    <span class="material-symbols-outlined absolute -top-10 -left-6 text-4xl text-green-700 opacity-40">
                        emergency
                    </span>

                    <h3 class="text-3xl font-bold mb-6 hover:text-green-700 transition">
                        Our Mission
                    </h3>

                    <ul class="text-slate-500 text-sm leading-relaxed list-disc pl-5 space-y-3 hover:text-slate-700 transition">
                        <li>
                            Provide top-quality fertilizers for farmers and gardeners.
                        </li>
                        <li>
                            Increase productivity while protecting soil fertility.
                        </li>
                        <li>
                            Promote sustainable agriculture practices.
                        </li>
                    </ul>

                </div>

                <div class="md:w-1/2 relative flex justify-center">

                    <div class="w-[380px] aspect-square overflow-hidden shadow-2xl transition duration-500 hover:scale-105"
                         style="clip-path: polygon(25% 0%,75% 0%,100% 50%,75% 100%,25% 100%,0% 50%);">

                        <img src="~/images/Hero_shop.png"
                             alt="Mission"
                             class="w-full h-full object-cover" />

                    </div>

                    <span class="material-symbols-outlined absolute -bottom-10 -right-10 text-8xl text-green-700 opacity-20 animate-pulse">
                        eco
                    </span>

                </div>

            </div>

            <!-- PRODUCTS -->
            <div class="flex flex-col md:flex-row items-center gap-16">

                <div class="md:w-1/2 relative flex justify-center">

                    <div class="w-[380px] aspect-square overflow-hidden shadow-2xl transition duration-500 hover:scale-105"
                         style="clip-path: polygon(25% 0%,75% 0%,100% 50%,75% 100%,25% 100%,0% 50%);">

                        <img src="~/images/Farma Fer.png"
                             alt="Products"
                             class="w-full h-full object-cover" />

                    </div>

                    <span class="material-symbols-outlined absolute -bottom-8 -left-8 text-8xl text-green-700 opacity-20 animate-bounce">
                        waves
                    </span>

                </div>

                <div class="md:w-1/2 text-right">

                    <h3 class="text-3xl font-bold mb-6 hover:text-green-700 transition">
                        Our Products
                    </h3>

                    <ul class="text-slate-500 text-sm leading-relaxed list-disc pl-5 space-y-3 hover:text-slate-700 transition">
                        <li>Organic, liquid and slow-release fertilizers</li>
                        <li>Strong roots and better yield nutrients</li>
                        <li>Eco-friendly and sustainable solutions</li>
                    </ul>

                </div>

            </div>

            <!-- COMMITMENT -->
            <div class="flex flex-col md:flex-row items-center gap-16">

                <div class="md:w-1/2">

                    <h3 class="text-3xl font-bold mb-6 hover:text-green-700 transition">
                        Our Commitment
                    </h3>

                    <p class="text-slate-500 text-sm leading-relaxed hover:text-slate-700 transition">
                        We are committed to helping farmers succeed by providing
                        reliable fertilizer products and continuous innovation.
                        Agri-Mitra supports sustainable farming practices for a greener future.
                    </p>

                </div>

                <div class="md:w-1/2 flex justify-center">

                    <div class="w-[380px] aspect-square overflow-hidden shadow-2xl transition duration-500 hover:scale-105"
                         style="clip-path: polygon(25% 0%,75% 0%,100% 50%,75% 100%,25% 100%,0% 50%);">

                        <img src="~/images/Hero_shop.png"
                             alt="Commitment"
                             class="w-full h-full object-cover" />

                    </div>

                </div>

            </div>

        </div>
    </section>

    <!-- CONTACT -->
    <section class="py-20 bg-[#F5F5F3] border-t border-gray-200">

        <div class="max-w-6xl mx-auto px-6">

            <div class="text-center mb-16">

                <h2 class="text-4xl font-bold mb-4 hover:text-green-700 transition">
                    AGRI-MITRA . We're here
                </h2>

                <p class="text-slate-500 text-sm max-w-lg mx-auto">
                    Helping farmers connect with trusted fertilizer suppliers.
                </p>

            </div>

            <div class="grid md:grid-cols-2 gap-20 max-w-4xl mx-auto">

                <div>
                    <h4 class="font-bold text-lg mb-4 uppercase">
                        Office Location
                    </h4>

                    <p class="text-slate-500 text-sm leading-relaxed">
                        Rajkot <br />
                        Gujarat 360001 <br />
                        India
                    </p>
                </div>

                <div>
                    <h4 class="font-bold text-sm mb-4 uppercase">
                        Subscribe
                    </h4>

                    <div class="flex border-b border-gray-300 pb-2 items-center">

                        <input class="w-full bg-transparent border-none text-sm outline-none"
                               placeholder="Enter your email address" />

                        <span class="material-symbols-outlined text-green-700 cursor-pointer hover:scale-125 transition">
                            mail
                        </span>

                    </div>

                </div>

            </div>

        </div>

    </section>

</div>